{
  "name": "ecommerce-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev --workspace @apps/api",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "infra:down": "docker compose -f infra/docker/compose.yml down -v",
    "infra:logs": "docker compose -f infra/docker/compose.yml logs -f",
    "infra:up": "docker compose -f infra/docker/compose.yml up -d",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,cjs,mjs,ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.21.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "prisma": "^6.18.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0"
  }
}
