API_PREFIX=/api/v1
APP_NAME=ecommerce-api
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_BCRYPT_SALT_ROUNDS=12
AUTH_JWT_ACCESS_SECRET=dev-access-secret-change-me-at-least-32-chars
AUTH_JWT_REFRESH_SECRET=dev-refresh-secret-change-me-at-least-32-chars
AUTH_REFRESH_TOKEN_COOKIE_NAME=refresh_token
AUTH_REFRESH_TOKEN_TTL_DAYS=7
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_platform?schema=public
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
HOST=0.0.0.0
IDEMPOTENCY_TTL_HOURS=24
LOG_LEVEL=info
NODE_ENV=development
OTEL_ENABLED=false
OTEL_SERVICE_VERSION=0.1.0
PORT=4000
