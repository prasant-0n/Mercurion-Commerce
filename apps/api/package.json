{
  "name": "@apps/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --max-warnings=0",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:seed": "tsx src/scripts/seed-rbac.ts",
    "start": "node dist/server.js",
    "test:integration": "tsx src/scripts/run-integration-tests.ts",
    "test:unit": "vitest run tests/unit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jose": "^6.2.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^4.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "pg": "^8.20.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "vitest": "^4.1.5"
  }
}
