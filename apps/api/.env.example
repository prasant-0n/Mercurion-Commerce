API_PREFIX=/api/v1
APP_NAME=ecommerce-api
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_BCRYPT_SALT_ROUNDS=12
AUTH_JWT_ACCESS_SECRET=dev-access-secret-change-me-at-least-32-chars
AUTH_JWT_REFRESH_SECRET=dev-refresh-secret-change-me-at-least-32-chars
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_REFRESH_TOKEN_COOKIE_NAME=refresh_token
AUTH_REFRESH_TOKEN_TTL_DAYS=7
CART_MAX_LINES=100
CART_MAX_QUANTITY_PER_LINE=99
CART_RATE_LIMIT_MAX_REQUESTS=60
CART_SCHEMA_VERSION=1
CART_TTL_DAYS=30
CHECKOUT_PAYMENT_TIMEOUT_MS=900000
CHECKOUT_RATE_LIMIT_MAX_REQUESTS=20
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_platform?schema=public
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
HOST=0.0.0.0
IDEMPOTENCY_TTL_HOURS=24
INVENTORY_RESERVATION_EXPIRY_BATCH_SIZE=500
INVENTORY_RESERVATION_EXPIRY_INTERVAL_MS=30000
INVENTORY_RESERVATION_MAX_RETRIES=3
INVENTORY_RESERVATION_TTL_SECONDS=900
LOG_LEVEL=info
MONGODB_URL=mongodb://127.0.0.1:27017/ecommerce_platform?replicaSet=rs0
NODE_ENV=development
OTEL_ENABLED=false
OTEL_SERVICE_VERSION=0.1.0
PAYMENT_CHECKOUT_BASE_URL=https://checkout.example.test/payments
PAYMENT_PROVIDER=razorpay
PAYMENT_RECONCILIATION_BATCH_SIZE=100
PAYMENT_RECONCILIATION_INTERVAL_MS=60000
PAYMENT_RECONCILIATION_STALE_MS=300000
PORT=4000
RAZORPAY_WEBHOOK_SECRET=dev-razorpay-webhook-secret
REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
REQUEST_BODY_LIMIT=1mb
WORKERS_ENABLED=true
